<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QRScanner.Pages.MainScanPage"
             xmlns:viewmodel="clr-namespace:QRScanner.ViewModel"
             x:DataType="viewmodel:MainViewModel"
             Title="MainScanPage">


    <Grid RowDefinitions="100, Auto, *"
          ColumnDefinitions=".75*, .25*"
          Padding="10">
        <Image Grid.ColumnSpan="2"
               Source="dotnet_bot.png"
               Background="Orange"/>
        <Entry Placeholder="Enter task"
               Text="{Binding Text}"
               Grid.Row="1"/>
        <Button Text="Add"
                Command="{Binding AddCommand}"
                Grid.Row="1"
                Grid.Column="1"/>

        <Entry  x:Name="item_codeEntryField"  Placeholder="Item"  Grid.Row="2">
            <Entry.GestureRecognizers Direction="Right" swipped="OnSwipped"/>
        </Entry>

        <CollectionView Grid.Row="3" Grid.ColumnSpan="2"
                        ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="{x:Type x:String}">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete" 
                                           BackgroundColor="Red" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Grid Padding="0,5">
                            <Border  StrokeShape="RoundRectangle 5,5,5,5">
                                <Label 
                                    Text="{Binding .}"
                                   FontSize=" 20">
                                    <Label.GestureRecognizers>
                                        <SwipeGestureRecognizer Direction="Right" Swiped="OnSwiped"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>
                        </Grid>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>

