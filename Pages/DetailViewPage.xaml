             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QRScanner.Pages.DetailViewPage"
             Title="DetailViewPage">
    
    <FlexLayout Direction="Column">


        <VerticalStackLayout Padding="10" FlexLayout.Basis="700" BackgroundColor="Beige">
