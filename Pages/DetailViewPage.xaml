    -->

            <Grid ColumnSpacing="10" RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <!-- New column for Action -->
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header Row -->
                <Label Text="Payment ID" Grid.Row="0" Grid.Column="0" VerticalOptions="Center" HorizontalOptions="Center"/>
                <Label Text="Item Code" Grid.Row="0" Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Center"/>
                <Label Text="Transaction Type" Grid.Row="0" Grid.Column="2" VerticalOptions="Center" HorizontalOptions="Center"/>
                <Label Text="Amount" Grid.Row="0" Grid.Column="3" VerticalOptions="Center" HorizontalOptions="Center"/>
                <Label Text="Action" Grid.Row="0" Grid.Column="4" VerticalOptions="Center" HorizontalOptions="Center"/>
                <!-- New header -->

                <!-- Entry Row -->
                <Entry x:Name="paymentIdEntryField" Grid.Row="1" Grid.Column="0" Text="{Binding SelectedItem.PaymentId, Mode=TwoWay}"/>
                <Entry x:Name="itemCodeEntryField" Grid.Row="1" Grid.Column="1" Text="{Binding SelectedItem.ItemCode, Mode=TwoWay}"/>
                <Picker x:Name="transactionTypePicker"
                        Grid.Row="1" Grid.Column="2"
                        VerticalOptions="Center"
                        HorizontalOptions="End"
                        WidthRequest="150"
                        SelectedIndexChanged="OnPickerSelectedIndexChanged">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Cash</x:String>
                            <x:String>Card</x:String>
                            <x:String>Donation</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                    <Picker.SelectedIndex>1</Picker.SelectedIndex>
                </Picker>
                <Entry x:Name="amountEntryField" Grid.Row="1" Grid.Column="3" Text="{Binding SelectedItem.Amount, Mode=TwoWay, StringFormat='{0:C}'}" Keyboard="Numeric"/>
                <Button x:Name="applyButton" Grid.Row="1" Grid.Column="4" Text="Apply" Clicked="savePaymentTransactionButton_Clicked" />
                <!-- New button -->

                <!-- Button Row -->
                <Button x:Name="saveButton" Grid.Row="2" Grid.Column="1" Text="Save" Command="{Binding SaveCommand}" />
                <Button x:Name="clearButton" Grid.Row="2" Grid.Column="2" Text="Clear" Command="{Binding ClearCommand}" />
            </Grid>



            <ListView x:Name="listView" FlexLayout.Grow="1" HasUnevenRows="True" ItemTapped="listView_ItemTapped">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <Grid Padding="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <!-- PaymentId -->
                                    <ColumnDefinition Width="3*" />
                                    <!-- ItemCode -->
                                    <ColumnDefinition Width="2*" />
                                    <!-- TransactionType -->
                                    <ColumnDefinition Width="2.5*" />
                                    <!-- Amount -->
                                    <ColumnDefinition Width="0.5*" />
                                    <!-- Spacer -->
                                    <ColumnDefinition Width="2*" />
                                    <!-- Created -->
                                </Grid.ColumnDefinitions>

                                <Label x:Name="PaymentIdLabel" Grid.Column="0" Text="{Binding PaymentId}" FontSize="17" />
                                <Label x:Name="ItemCodeLabel" Grid.Column="1" Text="{Binding ItemCode}" FontSize="17" FontAttributes="Bold" />
                                <Label x:Name="TransactionTypeLabel" Grid.Column="2" Text="{Binding TransactionType}" FontSize="17" />
                                <Label x:Name="AmountLabel" Grid.Column="3" Text="{Binding Amount, StringFormat='{0:C}'}" FontSize="17" HorizontalTextAlignment="End" />
                                <!-- Spacer -->
                                <Label x:Name="CreatedLabel" Grid.Column="5" Text="{Binding Created, StringFormat='{0:dd/MM/yyyy HH:mm}'}" FontSize="17" />
                            </Grid>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </VerticalStackLayout>
    </FlexLayout>
</ContentPage>