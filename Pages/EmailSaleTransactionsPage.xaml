<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QRScanner.Pages.EmailSaleTransactionsPage"
             Title="Email, Password, and Date">

    <StackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20" Spacing="10">
        <!-- Email Entry -->
        <Entry Placeholder="Email" MaxLength="50" WidthRequest="300" x:Name="EmailEntry" />

        <!-- Password Entry -->
        <Entry Placeholder="Password" IsPassword="True" MaxLength="50" WidthRequest="300" x:Name="PasswordEntry" />

        <!-- Date Picker -->
        <DatePicker Format="dd/MM/yyyy" WidthRequest="300" x:Name="DatePicker" />

        <!-- Comments Editor -->
        <Editor Placeholder="Add comments..." 
                WidthRequest="300" 
                HeightRequest="100"
            AutoSize="TextChanges"
            x:Name="CommentsEditor" />

            <!-- Submit Button -->
            <Button Text="Submit" Clicked="OnSubmitClicked" />
    </StackLayout>
</ContentPage>