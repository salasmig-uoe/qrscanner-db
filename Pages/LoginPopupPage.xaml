<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QRScanner.Pages.LoginPopupPage"
             Title="LoginPopupPage">
    <VerticalStackLayout Padding="20" Spacing="10">
        <Label Text="Email" />
        <Entry x:Name="EmailEntry" Placeholder="Enter your email" />

        <Label Text="Password" />
        <Entry x:Name="PasswordEntry" Placeholder="Enter your password" IsPassword="True" />

        <Button Text="Submit" Clicked="OnSubmitClicked" />
    </VerticalStackLayout>
</ContentPage>