<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="QRScanner.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:QRScanner.Pages"
    Shell.FlyoutBehavior="Flyout"
    Title="QRScanner">
    <Shell.FlyoutHeader>
        <Grid HeightRequest="100" BackgroundColor="DarkSlateBlue">
            <!-- <Image Source="moon.png"/> -->
        </Grid>
    </Shell.FlyoutHeader>
    <FlyoutItem Title="Art Scanner">
        <ShellContent Title="Home"
                ContentTemplate="{DataTemplate local:QrArtHomePage}" />
        <ShellContent Title="Sale"
            ContentTemplate="{DataTemplate local:CreateSaleTransactionsPage}" />
        <ShellContent Title="Edit"
            ContentTemplate="{DataTemplate local:EditSaleTransactionsPage}" />
        <ShellContent Title="View"
            ContentTemplate="{DataTemplate local:ViewSaleTransactionsPage}" />
    </FlyoutItem>
</Shell>
